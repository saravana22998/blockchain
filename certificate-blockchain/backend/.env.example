# ==========================================
# OpenCerts Verification & Issuance Config
# ==========================================

# 1. Blockchain Connection (Sepolia Testnet)
# Get a free URL from Alchemy (https://www.alchemy.com/) or Infura
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# 2. Wallet Private Key
# The private key of the account used to deploy the Smart Contract and pay gas fees
PRIVATE_KEY=your_private_key_here

# 3. Smart Contract Address
# The Ethereum address of your deployed DocumentStore contract on Sepolia
DOCUMENT_STORE_ADDRESS=0xYourContractAddress

# 4. Identity Proof (DNS Name)
# The domain where you set up your TXT record (e.g. demo.champslms.com)
DNS_NAME=your-free-domain.com

# 5. Renderer URL
# URL of the custom Angular/React decentralized renderer you are using
# (For a default free template to verify it, leave as is)
RENDERER_URL=https://demo-renderer.opencerts.io
